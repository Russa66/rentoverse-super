{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the RentoVerse application, who can be either a landlord or a renter.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "userType": { "type": "string", "enum": ["Owner", "Tenant"] },
        "address": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "userType", "createdAt", "updatedAt"]
    },
    "RoomListing": {
      "title": "RoomListing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "locality": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "propertyType": { "type": "string" },
        "bhkCount": { "type": "string" },
        "areaSqFt": { "type": "number" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "landlordId", "title", "location", "monthlyRent"]
    },
    "ConnectivityTest": {
      "title": "ConnectivityTest",
      "type": "object",
      "description": "Data for testing Firestore connectivity.",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "timestamp": { "type": "string" },
        "userAgent": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Private user profiles."
    },
    "/room_listings/{listingId}": {
      "schema": { "$ref": "#/backend/entities/RoomListing" },
      "description": "Public property listings."
    },
    "/landlords/{userId}": {
      "schema": { "type": "object" },
      "description": "Sentinel for landlord role."
    },
    "/renters/{userId}": {
      "schema": { "type": "object" },
      "description": "Sentinel for renter role."
    },
    "/connectivity_tests/{testId}": {
      "schema": { "$ref": "#/backend/entities/ConnectivityTest" },
      "description": "Publicly accessible collection for connectivity testing."
    }
  }
}