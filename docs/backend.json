
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the RentoVerse platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UID) for the User."
        },
        "name": {
          "type": "string",
          "description": "Full name of the user."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "WhatsApp contact number."
        },
        "userType": {
          "type": "string",
          "enum": ["Owner", "Tenant", "Admin"],
          "description": "The primary role of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "userType", "createdAt", "updatedAt"]
    },
    "RoomListing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RoomListing",
      "type": "object",
      "description": "A property or room available for rent.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "locality": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "areaSqFt": { "type": "number" },
        "bhkCount": { "type": "string" },
        "propertyType": { "type": "string" },
        "waterSupplyCondition": { "type": "string" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "idealFor": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "landlordId", "title", "location", "monthlyRent", "isActive"]
    },
    "RoomRequirement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RoomRequirement",
      "type": "object",
      "description": "A tenant's search preference.",
      "properties": {
        "id": { "type": "string" },
        "renterId": { "type": "string" },
        "locationFilter": { "type": "string" },
        "maxRent": { "type": "number" },
        "propertyType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "renterId", "locationFilter", "maxRent"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and settings."
    },
    "/room_listings/{listingId}": {
      "schema": { "$ref": "#/backend/entities/RoomListing" },
      "description": "Publicly browsable property listings."
    },
    "/users/{userId}/room_requirements/{requirementId}": {
      "schema": { "$ref": "#/backend/entities/RoomRequirement" },
      "description": "A tenant's specific room requests."
    }
  }
}
