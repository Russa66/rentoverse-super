
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of RentoVerse who can act as both landlord and tenant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "RoomListing": {
      "title": "RoomListing",
      "type": "object",
      "description": "A property listing posted by a proprietor (landlord).",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "locality": { "type": "string" },
        "monthlyRent": { "type": "number" },
        "propertyType": { "type": "string" },
        "bhkCount": { "type": "string" },
        "areaSqFt": { "type": "number" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SavedSearchRequest": {
      "title": "SavedSearchRequest",
      "type": "object",
      "description": "A room search requirement posted by a tenant.",
      "properties": {
        "id": { "type": "string" },
        "renterId": { "type": "string" },
        "locationFilter": { "type": "string" },
        "maxRent": { "type": "number" },
        "propertyType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/room_listings/{listingId}": {
      "schema": { "$ref": "#/backend/entities/RoomListing" },
      "description": "Public property listings posted by proprietors."
    },
    "/saved_search_requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/SavedSearchRequest" },
      "description": "Public tenant requirements."
    },
    "/users/{userId}/listings/{listingId}": {
      "schema": { "$ref": "#/backend/entities/RoomListing" },
      "description": "Private proprietor listings tracking."
    },
    "/users/{userId}/saved_search_requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/SavedSearchRequest" },
      "description": "Private tenant requirements tracking."
    }
  }
}
