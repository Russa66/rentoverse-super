rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Version: 1.0.1 - Global Auth-Based Access
    // Allows public read for all files (for property photos)
    // Allows write access for any authenticated user (including anonymous)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}