
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Version: 1.0.3 - Global Access for RentoVerse Assets
    // Authenticated users (including anonymous) can upload and manage their files
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
