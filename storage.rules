
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Version: 1.0.2 - Explicit Listing Access
    // Allows anyone to view property photos
    // Allows any authenticated user (including anonymous) to upload to any path
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
