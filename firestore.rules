rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.45 - Definitive Public Marketplace Access
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin status if the user is signed in
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Public Marketplace: Properties
    match /room_listings/{listingId} {
      // ALLOW READ (get/list) for anyone - fixes the permission error for guests
      allow read: if true; 
      
      // Only registered users (phone/email) can create new listings
      allow create: if isRegistered();
      
      // Only the landlord who created it or an admin can edit/delete
      allow update, delete: if isOwner(resource.data.landlordId) || isAdmin();
    }

    // Public Marketplace: Requirements (Tenant Search)
    match /saved_search_requests/{requestId} {
      // Open for anyone to browse
      allow read: if true;
      
      // Only registered tenants can post their requirements
      allow create: if isRegistered();
      
      // Only the owner or an admin can manage the requirement
      allow update, delete: if isOwner(resource.data.renterId) || isAdmin();
    }

    // User Profiles & Private Tracking Data
    match /users/{userId} {
      // Profiles are private to the owner and admins
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /listings/{listingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /saved_search_requests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Audit Logs for Social Posts
    match /social_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isRegistered(); 
      allow update, delete: if isAdmin();
    }
  }
}