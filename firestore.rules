rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RENTOVERSE SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isParticipant(data) {
      return isSignedIn() && (
        request.auth.uid == data.renterId || 
        request.auth.uid == data.landlordId
      );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /room_requirements/{id} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /room_listings/{listingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.landlordId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.landlordId || isAdmin());
    }

    match /social_posts/{id} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}