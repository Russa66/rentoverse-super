rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- PUBLIC COLLECTIONS (GUESTS CAN VIEW) ---
    match /room_listings/{listingId} {
      // Allow anyone (even guests) to read/list rooms
      allow read: if true;
      // Only registered users can post or manage their own listings
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid);
    }

    match /saved_search_requests/{requestId} {
      // Allow anyone to see what people are looking for
      allow read: if true;
      // Only registered users can post their own search requirements
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.renterId == request.auth.uid);
    }

    // --- PRIVATE USER DATA ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
    
    // --- AUDIT LOGS (ADMIN ONLY) ---
    match /social_posts/{postId} {
      allow read: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      allow create: if isSignedIn();
    }
  }
}