rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.42 - Unified Public Marketplace Access
    // This version explicitly allows unrestricted READ access to marketplace collections
    // to resolve "Missing or insufficient permissions" errors for guest users.
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Public Marketplace Collections
    // Both room_listings and saved_search_requests are part of the open marketplace
    match /room_listings/{listingId} {
      allow read: if true; // Unrestricted browsing for guests and users
      
      // Mutations require a verified account
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.landlordId) || isAdmin();
    }

    match /saved_search_requests/{requestId} {
      allow read: if true; // Unrestricted browsing for everyone
      
      // Mutations require a verified account
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.renterId) || isAdmin();
    }

    // User Profiles & Private Data
    match /users/{userId} {
      // Profiles are private to the owner and admins
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Sub-collections like private listings tracking
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}