rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isLandlord() { return exists(/databases/$(database)/documents/landlords/$(request.auth.uid)); }

    match /users/{userId} {
      allow get: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /landlords/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /renters/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /room_listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /users/{userId}/listings/{listingId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/notifications/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /social_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    // Publicly accessible collection for connectivity testing
    match /connectivity_tests/{testId} {
      allow create: if true;
      allow read: if true;
    }
  }
}