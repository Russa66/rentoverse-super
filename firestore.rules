
rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.13 - Nested User Sub-collections for improved inheritance
    
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      // Allow users to read and manage their own profile
      allow read, write: if isOwner(userId) || isAdmin();

      // Private tracking of proprietor's own listings
      match /listings/{listingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Private tracking of tenant's own requirements
      match /saved_search_requests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Private notifications/alerts
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Proprietor Listings (Landlords) - Public
    match /room_listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isAdmin());
    }

    // Tenant Requirements (Renters) - Public
    match /saved_search_requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.renterId == request.auth.uid || isAdmin());
    }

    // System Paths
    match /connectivity_tests/{testId} {
      allow read, write: if true;
    }
  }
}
