
rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Any user signed in with Phone or Email is considered registered
    function isRegistered() {
      return isSignedIn() && (request.auth.token.firebase.sign_in_provider != 'anonymous');
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- PUBLIC COLLECTIONS (GUESTS CAN BROWSE) ---
    match /room_listings/{listingId} {
      // Explicitly allow get and list for anyone
      allow read: if true;
      // Registered users can create listings
      allow create: if isRegistered();
      // Only owners or admins can modify
      allow update, delete: if isRegistered() && (resource.data.landlordId == request.auth.uid || isAdmin());
    }

    match /saved_search_requests/{requestId} {
      allow read: if true;
      allow create: if isRegistered();
      allow update, delete: if isRegistered() && (resource.data.renterId == request.auth.uid || isAdmin());
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      // Profiles are public for trust
      allow read: if true;
      
      // Users can always safely write to their own isolated profile node 
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
    
    // --- SOCIAL POSTS AUDIT ---
    match /social_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isRegistered();
    }
  }
}
