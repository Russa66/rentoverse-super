rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.44 - Explicit Public Marketplace Access (Split Get/List)
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Public Marketplace: Properties
    match /room_listings/{listingId} {
      // Explicitly allow browsing for anyone (authenticated or not)
      allow get, list: if true; 
      
      // Only registered users (phone/email) can create new listings
      allow create: if isRegistered();
      
      // Only the landlord who created it or an admin can edit/delete
      allow update, delete: if isOwner(resource.data.landlordId) || isAdmin();
    }

    // Public Marketplace: Requirements (Tenant Search)
    match /saved_search_requests/{requestId} {
      // Open for anyone to browse
      allow get, list: if true;
      
      // Only registered tenants can post their requirements
      allow create: if isRegistered();
      
      // Only the owner or an admin can manage the requirement
      allow update, delete: if isOwner(resource.data.renterId) || isAdmin();
    }

    // User Profiles & Private Tracking Data
    match /users/{userId} {
      // Profiles and their internal sub-collections are private to the owner and admins
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Admin-only Audit Logs for Social Posts
    match /social_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isRegistered(); // Log is created when a user generates an AI post
      allow update, delete: if isAdmin();
    }
  }
}