
rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if the user is a registered user (not guest)
    function isRegistered() {
      return isSignedIn() && (request.auth.token.firebase.sign_in_provider != 'anonymous');
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- PUBLIC COLLECTIONS (GUESTS CAN BROWSE) ---
    match /room_listings/{listingId} {
      allow read: if true;
      allow create: if isRegistered();
      allow update, delete: if isRegistered() && (resource.data.landlordId == request.auth.uid || isAdmin());
    }

    match /saved_search_requests/{requestId} {
      allow read: if true;
      allow create: if isRegistered();
      allow update, delete: if isRegistered() && (resource.data.renterId == request.auth.uid || isAdmin());
    }

    // --- PRIVATE USER DATA ---
    match /users/{userId} {
      allow read: if true;
      allow write: if isRegistered() && (request.auth.uid == userId || isAdmin());
      
      match /{allSubcollections=**} {
        allow read, write: if isRegistered() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // --- SOCIAL POSTS AUDIT ---
    match /social_posts/{postId} {
      // Strictly protected: Only admins can read audit logs
      allow read: if isAdmin();
      // Any registered user can trigger a post creation
      allow create: if isRegistered();
    }
  }
}
