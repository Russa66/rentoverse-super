rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.43 - Robust Public Marketplace & Admin Moderation
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Public Marketplace: Properties
    match /room_listings/{listingId} {
      allow read: if true; // Open browsing for all
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.landlordId) || isAdmin();
    }

    // Public Marketplace: Requirements
    match /saved_search_requests/{requestId} {
      allow read: if true; // Open browsing for all
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.renterId) || isAdmin();
    }

    // User Profiles & Private Data
    match /users/{userId} {
      // Profiles are private to the owner and admins
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Private sub-collections (e.g., /users/{uid}/listings/{id})
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Social Post Audit Log (Admin Only)
    match /social_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isRegistered(); // Users create logs when they use AI
      allow update, delete: if isAdmin();
    }
  }
}