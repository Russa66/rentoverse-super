rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.46 - Robust Public Marketplace Access
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Public Marketplace: Properties
    match /room_listings/{listingId} {
      // Allow anyone to browse (get/list)
      allow read: if true; 
      
      // Only registered users can create
      allow create: if isRegistered();
      
      // Only the landlord or an admin can edit/delete
      allow update, delete: if isOwner(resource.data.landlordId) || isAdmin();
    }

    // Public Marketplace: Tenant Requirements
    match /saved_search_requests/{requestId} {
      allow read: if true;
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.renterId) || isAdmin();
    }

    // User Profiles & Private Data
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Handle all nested sub-collections (listings, search_requests, notifications)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Social Post Audit (Admin visibility only)
    match /social_posts/{postId} {
      allow read: if isAdmin();
      allow create: if isRegistered(); 
      allow update, delete: if isAdmin();
    }
  }
}