rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.41 - Explicit Public Marketplace Access
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRegistered() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Public Marketplace Listings (Landlords)
    match /room_listings/{listingId} {
      // Explicitly allow both document read (get) and collection query (list) for everyone
      allow get, list: if true;
      
      // Posting and management requires a registered account
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.landlordId) || isAdmin();
    }

    // Public Marketplace Requirements (Tenants)
    match /saved_search_requests/{requestId} {
      // Explicitly allow browsing for everyone
      allow get, list: if true;
      
      // Requirements also require registration to post
      allow create: if isRegistered();
      allow update, delete: if isOwner(resource.data.renterId) || isAdmin();
    }

    // User Profiles & Private Sub-collections
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}