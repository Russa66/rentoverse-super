rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.35 - Absolute Public Access for Marketplace
    
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    // Public Marketplace Listings (Landlords)
    // Explicitly allowing READ (get and list) for everyone (auth == null)
    match /room_listings/{listingId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.landlordId);
    }

    // Public Marketplace Requirements (Tenants)
    match /saved_search_requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.renterId);
    }

    // Private User Profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}