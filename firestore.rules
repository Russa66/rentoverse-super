rules_version = '2';
service firebase.firestore {
  match /databases/{database}/documents {
    // Version: 1.0.18 - Explicit sub-collection matches for query reliability and safer admin logic
    
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isAdmin() {
      // Safely check for admin status using exists() check first to avoid errors if doc missing
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Root user profiles
    match /users/{userId} {
      // Prioritize owner check to prevent unnecessary get() calls or recursion
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Explicitly match sub-collections for 'list' operations (queries)
      // This is more reliable for real-time listeners on sub-collections
      match /listings/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /saved_search_requests/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /notifications/{id} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Public Marketplace Listings (Landlords)
    match /room_listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isAdmin());
    }

    // Public Marketplace Requirements (Tenants)
    match /saved_search_requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.renterId == request.auth.uid || isAdmin());
    }
  }
}